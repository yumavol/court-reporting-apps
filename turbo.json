{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "start": {
      "persistent": true,
      "dependsOn": ["build"]
    },
    "lint": {}
  }
}
